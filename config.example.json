{
  "$comment": "Copy to config.json. API keys are read from env vars, not stored here.",

  "default_mode": "plan",
  "show_thinking": true,
  "verbose": false,
  "log_level": "info",

  "providers": [
    {
      "name": "deepseek",
      "type": "openai",
      "model": "deepseek-v4-flash",
      "base_url": "https://api.deepseek.com"
    },
    {
      "name": "openai",
      "type": "openai",
      "model": "gpt-4o",
      "base_url": "https://api.openai.com/v1"
    },
    {
      "name": "openrouter",
      "type": "openai",
      "model": "anthropic/claude-sonnet-4",
      "base_url": "https://openrouter.ai/api/v1"
    },
    {
      "name": "groq",
      "type": "openai",
      "model": "llama-3.3-70b-versatile",
      "base_url": "https://api.groq.com/openai/v1"
    },
    {
      "name": "ollama",
      "type": "openai",
      "model": "qwen2.5-coder:7b",
      "base_url": "http://localhost:11434/v1",
      "api_key_env": "OLLAMA_API_KEY"
    }
  ],

  "context_length": 1000000,
  "compression_threshold": 500000,

  "searxng_url": "https://search.yusiwen.cn",

  "sandbox": {
    "project_root": "/home/yusiwen/git/ai/TinyCode",
    "deny_commands": ["rm -rf /", "sudo", "reboot", "shutdown"]
  },

  "truncation": {
    "max_lines": 2000,
    "max_bytes": 204800,
    "output_dir": "/tmp/tinycode/truncated"
  },

  "agents": {
    "plan": {
      "max_steps": 20,
      "denied_tools": ["write_file", "git_commit", "sandbox_allow", "task", "skill_manage"]
    },
    "build": {
      "max_steps": 30
    },
    "explore": {
      "max_steps": 15,
      "allowed_tools": ["bash", "read_file", "search_files"]
    },
    "general": {
      "max_steps": 20,
      "denied_tools": ["write_file", "git_commit", "sandbox_allow", "task", "skill_manage"]
    }
  },

  "session_dir": "~/.tinycode/sessions",

  "lsp": {
    "enabled": false
  },

  "mcp_servers": [
    {
      "name": "example-stdio",
      "transport": "stdio",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem"]
    },
    {
      "name": "example-http",
      "transport": "http",
      "url": "http://localhost:9000/mcp",
      "headers": {
        "Authorization": "Bearer mytoken"
      }
    }
  ],

  "theme": "nord",

  "$env_vars_note": {
    "description": "API keys are loaded from environment variables. By default, the pattern is UPPER(NAME)_API_KEY. Use 'api_key_env' to specify a custom env var name (e.g., Ollama below).",
    "examples": {
      "DEEPSEEK_API_KEY": "set your DeepSeek API key",
      "OPENAI_API_KEY": "set your OpenAI API key",
      "OPENROUTER_API_KEY": "set your OpenRouter API key",
      "GROQ_API_KEY": "set your Groq API key"
    },
    "override": "To use a custom env var name, add 'api_key_env' to the provider config. Example: { name: 'ollama', api_key_env: 'OLLAMA_API_KEY' }"
  },

  "$new_fields": {
    "searxng_url": "Self-hosted SearXNG fallback for web_search. Remove or set to '' to disable.",
    "theme": "TUI theme name: 'default' or 'nord'",
    "context_length": "Maximum context window in tokens (default: 1000000)",
    "compression_threshold": "Token count threshold to trigger history compression (default: 500000)",
    "sandbox": {
      "project_root": "Restrict file tool access to this directory (default: current dir)",
      "deny_commands": "Shell commands that are always blocked"
    },
    "mcp_servers": "List of MCP servers. Supported transports: 'stdio' (local subprocess) and 'http' (remote endpoint)."
  }
}
