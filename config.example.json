{
  "$comment": "Copy to config.json. API keys are read from env vars, not stored here.",
  "default_mode": "plan",
  "glamour_style": "auto",
  "show_thinking": true,
  "verbose": false,
  "log_level": "info",

  "providers": [
    {
      "name": "deepseek",
      "type": "openai",
      "model": "deepseek-v4-flash",
      "base_url": "https://api.deepseek.com"
    },
    {
      "name": "claude",
      "type": "openai",
      "model": "claude-sonnet-4-20250514",
      "base_url": "https://api.anthropic.com"
    },
    {
      "name": "local-ollama",
      "type": "ollama",
      "model": "qwen3.5:2b",
      "base_url": "http://localhost:11434"
    }
  ],

  "truncation": {
    "max_lines": 2000,
    "max_bytes": 204800,
    "output_dir": "/tmp/tinycode/truncated"
  },

  "agents": {
    "plan": {
      "max_steps": 20,
      "denied_tools": ["write_file", "git_commit", "sandbox_allow", "task"]
    },
    "build": {
      "max_steps": 30
    },
    "explore": {
      "max_steps": 15,
      "allowed_tools": ["bash", "read_file", "search_files"]
    }
  },

  "session_dir": "~/.tinycode/sessions",
  "lsp": {
    "enabled": false
  },

  "$env_vars_note": {
    "description": "API keys are loaded from environment variables using the pattern: UPPER(NAME)_API_KEY",
    "examples": {
      "DEEPSEEK_API_KEY": "set your DeepSeek API key",
      "CLAUDE_API_KEY": "set your Anthropic/Claude API key"
    },
    "override": "To use a custom env var name, add 'api_key_env' to the provider config, e.g.: { ..., \"api_key_env\": \"MY_CUSTOM_KEY\" }"
  }
}
